@startuml
skinparam style robustness

actor Visiteur
participant "IULogin : IU-login" as IU <<boundary>>
participant "CLogin : C-login" as C <<control>>
participant "Profile" as E2 <<entity>>

Visiteur -> IU : saisir(email, password)
Visiteur -> IU : clickBtnSignIn()

IU -> C : chercher()
C -> E2 : select()


alt identifiants corrects
    C --> IU : afficher("Accueil", profil)
else identifiants incorrects
    C --> IU : afficher("Erreur", "Email ou mot de passe invalide")
end


@enduml