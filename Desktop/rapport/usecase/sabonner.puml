@startuml
left to right direction
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 70

actor "Utilisateur" as Utilisateur
actor "Utilisateur premium" as UtilisateurPremium

rectangle "Systeme" as Systeme {
  usecase "s'abonner" as Abonner
}

Utilisateur -[hidden]down- UtilisateurPremium
UtilisateurPremium --|> Utilisateur
Utilisateur -- Abonner

@enduml
