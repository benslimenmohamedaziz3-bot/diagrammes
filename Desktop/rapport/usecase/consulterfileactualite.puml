@startuml
left to right direction
skinparam shadowing false
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 70

actor "visiteur" as Visiteur
actor "utilisateur" as Utilisateur
actor "utilisateur premium" as UtilisateurPremium
actor "editeur" as Editeur

rectangle "Systeme" as Systeme {
  usecase "consulter fil d'actualite" as ConsulterFileActualite
  usecase "filtrer actualite" as FiltrerActualite

  ConsulterFileActualite -[hidden]down- FiltrerActualite
}

rectangle "<<actor>>\nnewsdata.io" as NewsData

Visiteur -[hidden]down- Utilisateur
Utilisateur -[hidden]down- UtilisateurPremium
UtilisateurPremium -[hidden]down- Editeur

Utilisateur -up-|> Visiteur
UtilisateurPremium -up-|> Utilisateur
Editeur -up-|> Utilisateur

Visiteur -- ConsulterFileActualite
FiltrerActualite ..> ConsulterFileActualite : <<extend>>
ConsulterFileActualite -- NewsData

@enduml
