@startuml
allowmixing
left to right direction

actor "Visiteur" as Visiteur

class "IU-fil d'actualité" as Vue <<boundary>> {
  - actualites : List<News>
  + afficher()
}

class "C-fil d'actualité" as Controleur <<control>> {
  + charger()
}

package "Modeles" {
  class "News" as News <<entity>> {
    - idNews : int
    - titre : String
    - description : String
    - categorie : String
    - pays : String
    - source : String
    - datePublication : Date
    - url : String
    --
    + select()
  }
}

Visiteur -- Vue
Vue -- Controleur
Controleur -- News

@enduml