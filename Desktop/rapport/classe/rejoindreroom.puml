@startuml
allowmixing

actor "utilisateurpremuim" as Utilisateurpremium

class UI_Live <<boundary>> {
  -buttonOpenRoom : Button
  + click_button_open_room()
  + afficherRoom()
}

class LiveController <<control>> {
  + openRoom()
}

package "Modeles" {
class Room <<entity>> {
  - id : int
  - titre : String
  + select()
}

}

Utilisateurpremium -right- UI_Live
UI_Live -right- LiveController
LiveController -- Modeles

@enduml