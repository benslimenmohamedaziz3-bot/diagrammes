@startuml
allowmixing
left to right direction

actor "utilisateur" as UtilisateurActor

class "UI gérer profile" as UIGererProfile <<boundary>> {
  - firstName : string
  - lastName : string
  - emailAddress : string
  - profilePhoto : image
  - currentPassword : string
  - newPassword : string
  - confirmPassword : string
  -buttonChoosePhoto : button
  - buttonSaveProfile : button
  - buttonReset : button
  --
  + afficher(informationProfile)
  + modifier()
  + recuperer()
}

class "C gérer profile" as CGererProfile <<control>> {
  + charger()
  + changer()
}
package "Modeles" {
class "profile" as Profile <<entity>> {
  - id : int
  - email : String
  - password : String
  --
  + select()
  + update()
}

class "utilisateur" as Utilisateur <<entity>> {
  -id : int
  -nomComplet : string
  -photoProfil : string
  -role : string
  -estPremium : boolean
  -planPremium : string
  -datePremium : datetime
  --
  + select()
  + update()
}
}

UtilisateurActor -- UIGererProfile
UIGererProfile -- CGererProfile
CGererProfile -up- Modeles

Profile -- Utilisateur

@enduml